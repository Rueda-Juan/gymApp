{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "types": ["jest"],
    "paths": {
      "@/*": ["./*"],
      "backend/*": ["../Backend/src/*"],
      "@shared": ["../packages/shared/src/index.ts"],
      "@shared/*": ["../packages/shared/src/*", "../packages/shared/types/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../Backend" }
  ]
}