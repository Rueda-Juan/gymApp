{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "backend/*": ["../Backend/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../Backend/src/**/*.ts",
    "../Backend/src/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "../Backend/src/**/__tests__/*"
  ]
}
