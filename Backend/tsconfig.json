{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "strict": true,
    "types": ["jest", "node"],
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "../dist/Backend",
    "rootDir": "../",
    "paths": {
      "@domain/*": ["./src/domain/*"],
      "@application/*": ["./src/application/*"],
      "@infrastructure/*": ["./src/infrastructure/*"],
      "@shared": ["../packages/shared/src/index.ts"],
      "@shared/*": ["../packages/shared/src/*", "../packages/shared/types/*"]
    }
  },
  "include": ["src/**/*.ts", "../packages/shared/src/**/*.ts", "../packages/shared/types/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
