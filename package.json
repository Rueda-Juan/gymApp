{
  "name": "frontend",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "cd Frontend && npx expo start",
    "typecheck": "npm run typecheck:back && npm run typecheck:front",
    "typecheck:back": "cd Backend && npx tsc --noEmit",
    "typecheck:front": "cd Frontend && npx tsc --noEmit",
    "test": "npm run test:back && npm run test:front",
    "test:back": "cd Backend && npx jest",
    "test:front": "cd Frontend && npx jest",
    "testing": "npx tsc -b --watch",
    "install": "cd Backend && npm install && cd ../Frontend && npm install",
    "tree": "node tree.js",
    "lint:back": "cd Backend && npm run lint",
    "lint:front": "cd Frontend && npm run lint",
    "lint": "npm run lint:back && npm run lint:front"
  },
  "devDependencies": {
    "@testing-library/react-hooks": "^8.0.1",
    "@types/jest": "^30.0.0",
    "@types/react-test-renderer": "^19.1.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
