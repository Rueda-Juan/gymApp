{
  "name": "frontend",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "cd Frontend && npx expo start",
    "typecheck": "cd Backend && npx tsc --noEmit && cd ../Frontend && npx tsc --noEmit",
    "typecheck:back": "cd Backend && npx tsc --noEmit",
    "typecheck:front": "cd Frontend && npx tsc --noEmit",
    "test": "cd Backend && npx jest && cd ../Frontend && npx jest",
    "test:back": "cd Backend && npx jest",
    "test:front": "cd Frontend && npx jest",
    "testing": "npx tsc -b --watch",
    "install": "cd Backend && npm install && cd ../Frontend && npm install",
    "tree": "node tree.js"
  },
  "devDependencies": {
    "@testing-library/react-hooks": "^8.0.1",
    "@types/react-test-renderer": "^19.1.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
